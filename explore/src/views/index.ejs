<html>
	<head>
		<title>LucOs Arachne</title>
		<meta name="viewport" content="initial-scale=1.0, user-scalable=no, width=device-width" />
		<link href="/explore/style.css" rel="stylesheet" />
		<link rel="icon" href="/icon.png" />
		<link rel="manifest" href="/manifest.json" />
	</head>
	<body>
		<lucos-navbar bg-colour="#02666d">Arachne Knowledge Graph</lucos-navbar>
		<div id="intro">
			<img src="/icon.png" class="icon" />
			<span class='tagline'>Explore the knowledge graph of the entire lucOS ecosystem</span>
			<img src="/icon.png" class="icon" />
		</div>
		<div id='search' class="module">
			<h2>Search</h2>
			<form method='get' action='/explore/search'>
				<input type='text' name='q' />
				<input type='submit' value='Search' />
			</form>
		</div>
		<div class="module">
			<h2>Historical Events Timeline</h2>
			<a href="/explore/timeline" class="module-cta">View Historical Events Timeline &rarr;</a>
		</div>
		<div class="module">
			<h2>SPARQL Explorer</h2>
			<a href="/explore/sparql-explorer" class="module-cta">Open SPARQL Explorer &rarr;</a>
		</div>
		<script type="text/javascript" src="/explore/client.js"></script>
	</body>
</html>