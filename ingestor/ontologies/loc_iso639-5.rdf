<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#" xmlns:bf="http://id.loc.gov/ontologies/bibframe/" xmlns:bflc="http://id.loc.gov/ontologies/bflc/" xmlns:owl="http://www.w3.org/2002/07/owl#" xmlns:skos="http://www.w3.org/2004/02/skos/core#" xmlns:dcterms="http://purl.org/dc/terms/" xmlns:cc="http://creativecommons.org/ns#" xmlns:foaf="http://xmlns.com/foaf/0.1/">
  <owl:Class rdf:about="http://id.loc.gov/vocabulary/iso639-5/iso639-5_Language">
    <rdfs:label xml:lang="en">ISO639-5 Language</rdfs:label>
    <rdfs:comment xml:lang="en" rdf:parseType="Literal">
      <xhtml:div class="collectionAbout" title="About the Linguistic System for ISO639-5 Entries:" property="rdfs:comment" xmlns:xhtml="http://www.w3.org/1999/xhtml">
                  <xhtml:p>
                    An instance of an ISO639-5 Language.  A finite set of individuals are instances of an ISO639-5 Language.
                </xhtml:p>
                </xhtml:div>
    </rdfs:comment>
  </owl:Class>
