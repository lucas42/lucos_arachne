@prefix :      <http://base/#> .
@prefix tdb2:   <http://jena.apache.org/2016/tdb#>
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix ja:    <http://jena.hpl.hp.com/2005/11/Assembler#> .
@prefix fuseki: <http://jena.apache.org/fuseki#> .


# Raw data endpoint - write only
:dataService a fuseki:Service ;
	fuseki:name           "raw_arachne" ;
	fuseki:endpoint  [
		fuseki:name       "update";
		fuseki:operation  fuseki:update
	];
	fuseki:endpoint  [
		fuseki:name       "data";
		fuseki:operation  fuseki:gsp-rw
	];
	fuseki:serviceQuery   "query", "sparql" ;
	fuseki:dataset        :dataset ;
.

# Read endpoint - queries union of all named graphs (includes urn:lucos:inferred)
# Inference was removed from Fuseki; transitive closures are pre-computed by the ingestor.
:readService a fuseki:Service ;
	fuseki:dataset                 :dataset ;
	fuseki:name                    "arachne" ;
	fuseki:serviceQuery            "query", "sparql" ;
	fuseki:serviceReadGraphStore   "get" ;
.

# TDB2 dataset - union default graph enabled so queries without a GRAPH clause see all named graphs
:dataset rdf:type tdb2:DatasetTDB ;
	tdb2:location "/fuseki/run/databases/arachne" ;
	tdb2:unionDefaultGraph true ;
.
